<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>LTD Communication</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include("partials/navbar") %>

  <main class="page-shell auth-shell">
    <section class="page-card auth-card">
      <div class="auth-card-inner">
        <span class="section-label">Account Security</span>
        <div class="brand-line">LTD Communication</div>
        <h1 class="auth-title">Change Password</h1>
        <p class="auth-subtitle">Enter the current password first, then choose a new secure password.</p>

        <% if (error) { %>
          <div class="alert error">
            <%= error %>
          </div>
        <% } %>

        <% if (success) { %>
          <div class="alert success">
            <%= success %>
          </div>
        <% } %>

        <form action="/change-password" method="POST" class="form">
          <div class="field">
            <label>Current Password</label>
            <input
              type="password"
              name="currentPassword"
              placeholder="Enter current password"
              required
            >
          </div>

          <div class="field">
            <label>New Password</label>
            <input
              type="password"
              name="newPassword"
              placeholder="Enter new password"
              required
            >
          </div>

          <div class="password-rules">
            <strong>Password rules:</strong>
            <ul>
              <li>At least 10 characters</li>
              <li>At least one uppercase letter</li>
              <li>At least one lowercase letter</li>
              <li>At least one number</li>
              <li>At least one special character</li>
              <li>Cannot reuse last 3 passwords</li>
            </ul>
          </div>

          <button type="submit">Change Password</button>
        </form>

        <div class="footer-links auth-links">
          <a class="nav-link" href="/dashboard">Dashboard</a>
          <a class="nav-link" href="/logout">Logout</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
