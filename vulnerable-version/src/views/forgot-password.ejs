<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>LTD Communication</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include("partials/navbar") %>

  <main class="page-shell auth-shell">
    <section class="page-card auth-card">
      <div class="auth-card-inner">
        <span class="section-label">Password Recovery</span>
        <div class="brand-line">LTD Communication</div>
        <h1 class="auth-title">Generate Reset Token</h1>
        <p class="auth-subtitle">Enter the account email to start the existing password recovery flow.</p>

        <% if (error) { %>
          <div class="alert error">
            <%= error %>
          </div>
        <% } %>

        <% if (success) { %>
          <div class="alert success">
            <%= success %>
          </div>
        <% } %>

        <% if (demoToken) { %>
          <div class="token-callout">
            A reset token was generated for the secure demo flow. Check the console, then continue to the reset page.
          </div>

          <div class="action-row">
            <a class="button secondary" href="/reset-password?email=<%= encodeURIComponent(email) %>">
              Continue to Reset Password
            </a>
          </div>
        <% } %>

        <form action="/forgot-password" method="POST" class="form">
          <div class="field">
            <label>Email</label>
            <input
              type="email"
              name="email"
              value="<%= email || '' %>"
              placeholder="name@company.com"
              required
            >
          </div>

          <button type="submit">Generate Reset Token</button>
        </form>

        <div class="footer-links auth-links">
          <a class="nav-link" href="/login">Login</a>
          <a class="nav-link" href="/">Home</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
